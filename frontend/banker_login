<!DOCTYPE html>
<html>
<head>
<title>Banker Login</title>
</head>
<body>

<h2>Banker Login</h2>

<input id="bankerId" placeholder="Banker ID"><br>
<input id="pass" type="password" placeholder="Password"><br><br>

<button onclick="login()">Login</button>

<p id="msg"></p>

<script>
function login(){

let id = bankerId.value;
let pass = document.getElementById("pass").value;

let data = JSON.parse(localStorage.getItem("banker_"+id));

if(data && data.pass === pass){
window.location.href = "banker_dashboard.html";
}else{
document.getElementById("msg").innerText = "Invalid credentials";
}

}
</script>

</body>
</html>
