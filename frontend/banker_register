<!DOCTYPE html>
<html>
<head>
<title>Banker Register</title>
</head>
<body>

<h2>Banker Registration</h2>

<input id="name" placeholder="Name"><br>
<input id="phone" placeholder="Phone"><br>
<input id="email" placeholder="Email"><br>
<input id="bankerId" placeholder="Banker ID"><br>
<input id="pass" type="password" placeholder="Password"><br>
<input id="confirm" type="password" placeholder="Confirm Password"><br><br>

<button onclick="register()">Register</button>

<p id="msg"></p>

<script>
function register(){

let p = document.getElementById("pass").value;
let c = document.getElementById("confirm").value;

if(p !== c){
document.getElementById("msg").innerText = "Passwords do not match";
return;
}

let user = {
name: name.value,
phone: phone.value,
email: email.value,
bankerId: bankerId.value,
pass: p
};

localStorage.setItem("banker_"+bankerId.value, JSON.stringify(user));

window.location.href = "banker_dashboard.html";

}
</script>

</body>
</html>
